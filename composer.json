{
    "name": "hakim/laravel-claude-chat",
    "description": "A plug-and-play Claude AI chatbot widget for Laravel apps",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Hakim\\ClaudeChat\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hakim\\ClaudeChat\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hakim\\ClaudeChat\\ChatServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
